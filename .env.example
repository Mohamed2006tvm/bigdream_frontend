# Production build: full API base URL (must match your deployed backend).
VITE_API_URL=https://bigdream-backend-production-2c10.up.railway.app/api

# Dev: leave VITE_API_URL unset to use the Vite proxy (/api → backend) and avoid CORS.
# Override VITE_API_URL in dev only if you run the API locally and have CORS configured.
# VITE_API_URL=http://localhost:3000/api

# Dev proxy target when using /api (no VITE_API_URL). Defaults to Railway if unset.
# VITE_PROXY_TARGET=https://bigdream-backend-production-2c10.up.railway.app
