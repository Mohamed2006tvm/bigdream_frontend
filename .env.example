# Production build: full API base URL (must match your deployed backend).
VITE_API_URL=https://bigdream-backend.vercel.app/api

# Optional — axios timeouts in ms (defaults: 90000 general, 120000 login)
# VITE_API_TIMEOUT_MS=90000
# VITE_LOGIN_TIMEOUT_MS=120000

# Dev: leave VITE_API_URL unset to use the Vite proxy (/api → backend) and avoid CORS.
# Override VITE_API_URL in dev only if you run the API locally and have CORS configured.
# VITE_API_URL=http://localhost:3000/api

# Dev proxy target when using /api (no VITE_API_URL). Defaults to production API if unset.
# VITE_PROXY_TARGET=https://bigdream-backend.vercel.app
